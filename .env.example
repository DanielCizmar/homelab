# Grafana Cloud Prometheus
GRAFANA_CLOUD_METRICS_URL=https://prometheus-prod-XX-prod-XX-XXX.grafana.net/api/prom/push

# Grafana Cloud Metrics instance ID
GRAFANA_CLOUD_METRICS_USERNAME=replace_me

# Cloud Access Policy token with metrics:write permission
GRAFANA_CLOUD_METRICS_PASSWORD=replace_me

# Name displayed as the instance label in Grafana
ALLOY_HOSTNAME=raspberrypi

# Pi-hole web dashboard password
PIHOLE_WEBPASSWORD=replace_me
